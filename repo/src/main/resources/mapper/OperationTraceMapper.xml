<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eaglepoint.venue.mapper.OperationTraceMapper">
    <resultMap id="TraceMap" type="com.eaglepoint.venue.domain.OperationTrace">
        <id property="id" column="id"/>
        <result property="traceId" column="trace_id"/>
        <result property="actor" column="actor"/>
        <result property="action" column="action"/>
        <result property="entityType" column="entity_type"/>
        <result property="entityRef" column="entity_ref"/>
        <result property="payload" column="payload"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    <insert id="insert" parameterType="com.eaglepoint.venue.domain.OperationTrace" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_trace (trace_id, actor, action, entity_type, entity_ref, payload)
        VALUES (#{traceId}, #{actor}, #{action}, #{entityType}, #{entityRef}, #{payload})
    </insert>
    <select id="findAll" resultMap="TraceMap">SELECT * FROM operation_trace ORDER BY id DESC</select>
</mapper>
