<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eaglepoint.venue.mapper.RefundTransactionMapper">
    <resultMap id="RefundMap" type="com.eaglepoint.venue.domain.RefundTransaction">
        <id property="id" column="id"/>
        <result property="paymentId" column="payment_id"/>
        <result property="transactionRef" column="transaction_ref"/>
        <result property="refundAmount" column="refund_amount"/>
        <result property="refundType" column="refund_type"/>
        <result property="reason" column="reason"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    <insert id="insert" parameterType="com.eaglepoint.venue.domain.RefundTransaction" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO refund_transaction (payment_id, transaction_ref, refund_amount, refund_type, reason)
        VALUES (#{paymentId}, #{transactionRef}, #{refundAmount}, #{refundType}, #{reason})
    </insert>
    <select id="findAll" resultMap="RefundMap">SELECT * FROM refund_transaction ORDER BY id DESC</select>
</mapper>
