<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eaglepoint.venue.mapper.SettlementCallbackMapper">
    <resultMap id="CbMap" type="com.eaglepoint.venue.domain.SettlementCallback">
        <id property="id" column="id"/>
        <result property="transactionRef" column="transaction_ref"/>
        <result property="gatewayBatchRef" column="gateway_batch_ref"/>
        <result property="settledAmount" column="settled_amount"/>
        <result property="callbackStatus" column="callback_status"/>
        <result property="source" column="source"/>
        <result property="callbackAt" column="callback_at"/>
    </resultMap>
    <insert id="insert" parameterType="com.eaglepoint.venue.domain.SettlementCallback" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO settlement_callback (transaction_ref, gateway_batch_ref, settled_amount, callback_status, source, callback_at)
        VALUES (#{transactionRef}, #{gatewayBatchRef}, #{settledAmount}, #{callbackStatus}, #{source}, #{callbackAt})
    </insert>
    <select id="findByTransactionRef" parameterType="string" resultMap="CbMap">SELECT * FROM settlement_callback WHERE transaction_ref=#{transactionRef}</select>
    <select id="findAll" resultMap="CbMap">SELECT * FROM settlement_callback ORDER BY id DESC</select>
</mapper>
