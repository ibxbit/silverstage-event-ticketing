<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eaglepoint.venue.mapper.StandMapper">

    <resultMap id="StandMap" type="com.eaglepoint.venue.domain.Stand">
        <id property="id" column="id"/>
        <result property="sessionId" column="session_id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
    </resultMap>

    <select id="findBySessionId" parameterType="long" resultMap="StandMap">
        SELECT id, session_id, code, name
        FROM stand
        WHERE session_id = #{sessionId}
        ORDER BY id
    </select>
</mapper>
