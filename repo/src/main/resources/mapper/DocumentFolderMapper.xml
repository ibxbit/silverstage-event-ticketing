<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eaglepoint.venue.mapper.DocumentFolderMapper">

    <resultMap id="DocumentFolderMap" type="com.eaglepoint.venue.domain.DocumentFolder">
        <id property="id" column="id"/>
        <result property="folderPath" column="folder_path"/>
    </resultMap>

    <select id="findByPath" parameterType="string" resultMap="DocumentFolderMap">
        SELECT id, folder_path
        FROM document_folder
        WHERE folder_path = #{folderPath}
    </select>

    <select id="findById" parameterType="long" resultMap="DocumentFolderMap">
        SELECT id, folder_path
        FROM document_folder
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.eaglepoint.venue.domain.DocumentFolder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO document_folder (folder_path)
        VALUES (#{folderPath})
    </insert>
</mapper>
