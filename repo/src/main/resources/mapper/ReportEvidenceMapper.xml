<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eaglepoint.venue.mapper.ReportEvidenceMapper">

    <resultMap id="ReportEvidenceMap" type="com.eaglepoint.venue.domain.ReportEvidence">
        <id property="id" column="id"/>
        <result property="reportId" column="report_id"/>
        <result property="storedPath" column="stored_path"/>
        <result property="originalFileName" column="original_file_name"/>
        <result property="contentType" column="content_type"/>
        <result property="fileSize" column="file_size"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.eaglepoint.venue.domain.ReportEvidence" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO report_evidence (report_id, stored_path, original_file_name, content_type, file_size)
        VALUES (#{reportId}, #{storedPath}, #{originalFileName}, #{contentType}, #{fileSize})
    </insert>

    <select id="findByReportId" parameterType="long" resultMap="ReportEvidenceMap">
        SELECT id, report_id, stored_path, original_file_name, content_type, file_size, created_at
        FROM report_evidence
        WHERE report_id = #{reportId}
        ORDER BY id
    </select>
</mapper>
