<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eaglepoint.venue.mapper.RevenueShareRecordMapper">
    <resultMap id="ShareMap" type="com.eaglepoint.venue.domain.RevenueShareRecord">
        <id property="id" column="id"/>
        <result property="transactionRef" column="transaction_ref"/>
        <result property="platformShare" column="platform_share"/>
        <result property="merchantShare" column="merchant_share"/>
        <result property="merchantCode" column="merchant_code"/>
        <result property="calculatedAt" column="calculated_at"/>
    </resultMap>
    <insert id="insert" parameterType="com.eaglepoint.venue.domain.RevenueShareRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO revenue_share_record (transaction_ref, platform_share, merchant_share, merchant_code)
        VALUES (#{transactionRef}, #{platformShare}, #{merchantShare}, #{merchantCode})
    </insert>
    <select id="findAll" resultMap="ShareMap">SELECT * FROM revenue_share_record ORDER BY id DESC</select>
</mapper>
